# =============================================================================
# fastapi-hexagonal-template - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables use the APP_ prefix.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# Application environment: local, dev, or prod
APP_ENVIRONMENT=local

# Enable debug mode (adds extra logging, stack traces in errors)
APP_DEBUG=true

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
APP_LOG_LEVEL=DEBUG
# Log format: text (human-readable) or json (structured)
APP_LOG_FORMAT=text

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (empty = CORS disabled)
# Example: http://localhost:3000,https://app.example.com
APP_CORS_ORIGINS=
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_ALLOW_METHODS=*
APP_CORS_ALLOW_HEADERS=*

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Both postgresql:// and postgresql+asyncpg:// are accepted (auto-converted).
APP_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app
APP_DATABASE_POOL_SIZE=5
APP_DATABASE_POOL_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Show detailed error messages in API responses (disable in prod!)
APP_FEATURE_DETAILED_ERRORS=true
# Enable request logging middleware
APP_FEATURE_REQUEST_LOGGING=true
